# ── Database ──────────────────────────────────────────────
POSTGRES_USER=orbit
POSTGRES_PASSWORD=orbit_secret
POSTGRES_DB=orbit
DATABASE_URL=postgres://orbit:orbit_secret@localhost:5432/orbit

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Encryption (API Key 저장용 AES-256-GCM) ───────────────
# 32바이트 hex 문자열 (openssl rand -hex 32 로 생성)
ENCRYPTION_KEY=change_me_to_32_byte_hex_string_here

# ── App ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
