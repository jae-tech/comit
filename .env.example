# ── Database ──────────────────────────────────────────────
POSTGRES_USER=comit
POSTGRES_PASSWORD=comit_secret
POSTGRES_DB=comit
DATABASE_URL=postgres://comit:comit_secret@localhost:5432/comit

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Encryption (API Key 저장용 AES-256-GCM) ───────────────
# 32바이트 hex 문자열 (openssl rand -hex 32 로 생성)
ENCRYPTION_KEY=change_me_to_32_byte_hex_string_here

# ── App ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
# FRONTEND_URL 에 demo.com.it 도 추가 (CORS 허용):
# FRONTEND_URL=http://localhost:3000,https://com.it,https://demo.com.it

# ── Demo 페이지 (공개 RAG 데모) ──────────────────────────
# 1) demo@com.it 계정으로 로그인 → 워크스페이스 생성 → 문서 업로드 → AI Provider 등록
# 2) 해당 계정/워크스페이스 UUID를 아래에 입력
DEMO_ENABLED=true      # false 로 설정하면 /demo/* 전체가 503 반환
DEMO_USER_ID=          # users.id (demo 운영자 계정 UUID)
DEMO_WORKSPACE_ID=     # workspaces.id (demo 워크스페이스 UUID)
DEMO_HIDE_DOCS=false   # true 로 설정하면 /demo/docs 응답에서 문서 목록 숨김

# 운영자 전용 인증 토큰 (절대 git에 커밋하지 말 것)
# openssl rand -hex 32 로 생성
DEMO_ADMIN_TOKEN=      # server-side only, never NEXT_PUBLIC_

# 프로덕션 demo 서브도메인 (기본값: demo.com.it)
# 로컬에서는 localhost:3000/demo 로 접근 (미들웨어가 리다이렉트 없이 통과시킴)
DEMO_DOMAIN=demo.com.it
